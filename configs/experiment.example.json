{
  "data_dir": "D:/实验五/全波段全变量DT",
  "output_dir": "D:/path/to/outputs/experiment_name",
  "train_sites": ["TRAIN_SITE_ID"],
  "val_sites": ["VAL_SITE_ID"],
  "test_sites": ["TEST_SITE_ID"],
  "features": {
    "forcing": [
      "SW_IN_F",
      "SW_IN_POT",
      "CO2_F_MDS",
      "P_F",
      "VPD_F",
      "TA_F",
      "TS_F_MDS_1",
      "SWC_F_MDS_1",
      "WS_F"
    ],
    "state": [
      "EPIC_Available_Mask",
      "Band317nm_Ref",
      "Band325nm_Ref",
      "Band340nm_Ref",
      "Band388nm_Ref",
      "Band443nm_Ref",
      "Band551nm_Ref",
      "Band680nm_Ref",
      "Band688nm_Ref",
      "Band764nm_Ref",
      "Band780nm_Ref",
      "Mean_SZA",
      "Mean_VZA",
      "Mean_RAA"
    ],
    "static": ["Lat", "Long"],
    "target": "GPP_DT_VUT_REF",
    "time": "date",
    "land_cover": "Veg_ID"
  },
  "window": {
    "seq_len": 96,
    "time_features": "cyclic",
    "require_regular": true,
    "max_gap_hours": 1,
    "max_span_hours": 95,
    "dt_clip_hours": 240
  },
  "scaling": "zscore",
  "scale_target": true,
  "model": {
    "kind": "tcn",
    "d_model": 64,
    "nhead": 4,
    "dropout": 0.1,
    "dim_feedforward": 128,
    "num_layers": 2,
    "num_mamba_layers": 4,
    "mamba_d_state": 16,
    "mamba_d_conv": 4,
    "mamba_expand": 2,
    "use_native_mamba": null,
    "cde_layers": 1,
    "cde_vector_field_dim": 128,
    "increment_scale": 1.0,
    "num_land_cover_classes": 13,
    "land_cover_embedding_dim": 8,
    "tcn_layers": 6,
    "normalized_tcn": false,
    "cross_attention_residual": false,
    "lag_encoding": "none",
    "static_context_mode": "repeated",
    "state_norm_first": false,
    "cross_fusion_mode": "replace",
    "cross_direction": "state_to_forcing",
    "temporal_pooling": "last"
  },
  "loss": "mse",
  "loss_options": {},
  "training": {
    "batch_size": 64,
    "epochs": 100,
    "learning_rate": 0.001,
    "patience": 10,
    "num_workers": 0,
    "seed": 42,
    "resume": true,
    "selection_metric": "macro_rmse",
    "station_balanced": false,
    "amp": false,
    "weight_decay": 0.0,
    "deterministic": true,
    "optimizer": "adam"
  },
  "evaluation": {
    "save_predictions": true,
    "save_plots": true,
    "moving_average_window": 12,
    "zoom_days": 30,
    "minimum_target": null,
    "evaluate_test": true
  },
  "cross_validation": {
    "enabled": false,
    "n_splits": 5,
    "seed": 42,
    "evaluate_test_each_fold": false
  }
}
